        <li>KYPHOSIS</li>
        <li>SCOLIOSIS</li>
        <li>KOILONYCHIA</li>
        <li>GENERALISED LYMPHEADENOPATHY</li>
        <li>PEDAL EDEMA</li>
        <li>HAIR</li>
        <li>SKIN</li>
        <li>EYE BROWS</li>
        <li>FROWNING</li>
        <li>EYES</li>
        <li>PAROTID</li>
        <li>NECK SWELLING</li>
        <li>DROOLING OF SALIVA</li>
        <li>NAILS</li>
        <li>DROOPING OF SHOULDER</li>
        <li>BREAST/GYNECOMASTIA</li>
        <li>OBVIOUS SWELLINGS</li>
        <li>GENETALIA[HERNIA,HYDROCELE]</li>
      </ol>
    </div>
    <div class="section">
      <h3>VITALS</h3>
      <ol>
        <li>TEMPERATURE : <span> </span>[in inflammatory swelling]</li>
        <li>PULSE : <span> </span>[in inflammatory swelling]</li>
        <li>B.P</li>
        <li>RR</li>
        <li>SPO2</li>
      </ol>
      <p><br>
      </p>
      <ol>
      </ol>
