          <ol>
            <li>Sore throat</li>
            <li>Difficulty swallowing</li>
            <li>Hoarseness</li>
            <li>Snoring</li>
          </ol>
        </li>
      </ol>
      <p><strong>Respiratory:</strong></p>
      <ol>
        <li>Cough</li>
        <li>Wheezing</li>
        <li>Shortness of breath</li>
        <li>Chest pain</li>
        <li>Hemoptysis</li>
      </ol>
      <p><strong>Cardiovascular:</strong></p>
      <ol>
        <li>Palpitations</li>
        <li>Chest pain</li>
        <li>Cyanosis</li>
        <li>Edema</li>
        <li>Exercise intolerance</li>
        <li>Syncope</li>
      </ol>
      <p><strong>Gastrointestinal:</strong></p>
      <ol>
        <li>Appetite</li>
        <li>Nausea</li>
