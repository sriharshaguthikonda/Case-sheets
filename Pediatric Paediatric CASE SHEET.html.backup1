        <li>Constipation</li>
        <li>Abdominal pain</li>
        <li>Distension</li>
        <li>Blood in stool</li>
        <li>Jaundice</li>
      </ol>
      <p><strong>Genitourinary:</strong></p>
      <ol>
        <li>Urinary frequency</li>
        <li>Urgency</li>
        <li>Dysuria</li>
        <li>Hematuria</li>
        <li>Enuresis</li>
        <li>Genital discharge/rash/pain</li>
      </ol>
      <p><strong>Musculoskeletal:</strong></p>
      <ol>
        <li>Joint pain/swelling</li>
        <li>Muscle pain/weakness</li>
        <li>Deformity</li>
        <li>Difficulty walking</li>
      </ol>
