    <div class="section">
      <h3>INVESTIGATIONS</h3>
      <ul>
        <li>TO CONFIRM &Icirc;&rdquo;</li>
        <ol>
          <li>Rheumatioid Arthritis</li>
          <ol>
            <li>FBC</li>
