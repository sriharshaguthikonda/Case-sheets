  <body> <button id="theme-toggle" title="Toggle dark mode">🌙 Dark Mode</button>
    <h3 class="General">MANAGEMENT PLAN</h3>
    <h4 class="General">OBO Urgency</h4>
    <ul>
      <li class="General">Urgent Admission:</li>
      <li class="General">Urgent Referral (2 weeks):</li>
      <li class="General">Routine Referral:</li>
      <li class="General">Handling In-House:</li>
    </ul>
    <h4 class="General">Patient-Specific Plan</h4>
    <ol>
      <li class="General">Want someone to listen in?</li>
      <li class="emergency">family coming?</li>
      <ol>
        <li>we can call ..... for you</li>
      </ol>
      <li>Initial Investigations
        <ul>
          <li class="General"><em>Consent </em></li>
          <li class="General cvs">Blood work: </li>
          <ul>
            <li class="surgery" style="left: -1px;">Prostate specific antigen</li>
          </ul>
          <li class="cvs">Imaging: </li>
          <ul>
            <li class="nephro">Urine dip stick</li>
            <li class="cvs">X- Ray</li>
            <ul>
              <li class="hematology">Multiple myeloma</li>
            </ul>
            <li class="cvs">MRI</li>
            <li class="cvs">CT Scan</li>
            <ul>
              <li class="nephro">Renal stones</li>
            </ul>
            <li class="cvs">Ultrasound</li>
          </ul>
          <li class="derma">Dermoscopy</li>
          <li class="derma">Photography</li>
          <li class="derma">Biopsy: </li>
          <ul>
            <li class="derma">Excisional biopsy - we dont sample biopsy</li>
            <ul>
              <li class="derma">Mole suspect</li>
              <li class="derma">BCC</li>
              <li class="derma">SCC</li>
            </ul>
            <li class="derma">if positive then wide excision</li>
            <li class="derma"><em>ADR </em>= <em>Complications</em></li>
            <ul>
              <li class="derma">bleeding</li>
              <li class="derma">infection</li>
              <li class="derma">pain</li>
              <li class="derma">scarring</li>
              <li class="derma">disfigurement</li>
            </ul>
          </ul>
          <li class="cvs">Further Investigations</li>
          <ul>
            <li class="cvs">Specialized tests: </li>
            <ul>
              <li class="surgery">Cystoscope</li>
              <li class="surgery">biopsy</li>
            </ul>
            <li class="cvs">Referrals: </li>
          </ul>
        </ul>
      </li>
    </ol>
    <ol>
      <li class="General">EXPLAIN FINDINGS</li>
      <li class="General">ICE : <br>
        <strong></strong></li>
      <li class="General"><strong>PROVISIONAL DIAGNOSIS :</strong></li>
      <ol>
        <li class="cvs">ANATOMICAL</li>
        <li class="cvs">ETIOLOGICAL</li>
        <li class="cvs">PATHOLOGICAL</li>
        <li class="cvs">CLINICAL</li>
      </ol>
      <li class="General">Treatment Plan
        <ul>
          <li class="General">Symptomatic treatment: </li>
          <li class="cvs">Specific treatment: </li>
          <li class="General">Consent </li>
          <li class="cvs">Non-Medical: </li>
          <ol>
            <li class="General">Watch and wait!</li>
            <li class="General">Behavior diary</li>
            <li class="Endocrine cvs cns">Diabetes</li>
            <ul class="Endocrine">
              <li class="Endocrine">food</li>
              <li class="Endocrine"><a href="https://chatgpt.com/g/g-685ef36778488191a2d2704177c22a64-plab-2-feedback/c/6865ad97-b148-8007-94b7-f44171ebd0cf#:%7E:text=DAFNE%20%28%E2%80%9CDose%20Adjustment%20For%20Normal%20Eating%E2%80%9D%29">
                  DAFNE</a> ("Dose Adjustment For Normal Eating")</li>
              <li class="Endocrine cvs">exercise</li>
            </ul>
            <li class="rheumatic">Chronic fatigue syndrome</li>
            <ol>
              <li class="rheumatic">CBT</li>
              <li class="rheumatic">Life style</li>
              <li class="rheumatic">not graded exercise </li>
            </ol>
            <li class="hematology">Thalassemia minor<br>
            </li>
            <ol>
              <li class="hematology">Counselling</li>
              <li class="hematology">Marrige counselling</li>
              <li class="hematology">Iron if Severe</li>
            </ol>
            <li class="nephro">Renal stones</li>
            <ol>
              <li class="nephro">Strainer for collecting Renal stones</li>
            </ol>
            <li class="derma">Eczema: </li>
            <ul class="derma">
              <li class="derma"> simple = Mouzterizers</li>
            </ul>
          </ol>
          <li class="cvs">Medical/</li>
          <ul>
            <li class="derma">Severe eczema</li>
            <ul>
              <li class="derma">steroids</li>
            </ul>
            <li class="derma">Acne</li>
            <ul>
              <li class="derma">Retenoids</li>
            </ul>
            <li class="derma">Scabies</li>
            <ul>
              <li class="derma">Permethrin / Ivermectin</li>
            </ul>
            <li class="cvs">Anti pyretic </li>
            <li class="cns">Anti epileptic</li>
            <ul>
              <li class="cns">Febrile seizures if the child is far away</li>
            </ul>
            <li class="cvs">Pain killers</li>
            <ul>
              <li class="nephro">UTI</li>
              <li class="nephro">Renal stones</li>
            </ul>
            <li class="cvs">Abx</li>
            <ul>
              <li class="nephro">UTI</li>
              <li class="nephro">Trimithoprim</li>
              <li class="nephro">Nitrofurantoin</li>
            </ul>
            <li class="surgery">Tamsulosin</li>
            <ul>
              <li class="surgery">BPH</li>
            </ul>
            <li class="surgery">Finasteride</li>
            <ul>
              <li class="surgery">BPH</li>
            </ul>
            <li class="hematology">Chemo</li>
            <li class="hematology">Radio</li>
            <li class="hematology">Steroids</li>
            <ul>
              <li class="hematology">ITP</li>
            </ul>
          </ul>
          <li class="surgery">Surgical</li>
          <ul>
            <li class="hematology">Stem cell </li>
            <li class="hematology">Bone Marrow Transplant</li>
            <li class="surgery">Splenectomy - </li>
            <ul>
              <li class="hematology">ITP severe</li>
            </ul>
            <li class="surgery">Stent</li>
            <ul>
              <li class="nephro">Renal stones</li>
            </ul>
            <li class="surgery">PCNL</li>
            <ul>
              <li class="nephro">Renal stones</li>
            </ul>
            <li class="derma">cant do simple cosmetic procedures</li>
            <li class="derma">if lesions causes other problem then Sgx</li>
          </ul>
          <li class="cvs">Admission required: Yes/No</li>
        </ul>
      </li>
      <li class="General">Follow Up
        <ul>
          <li class="cvs">Frequency: </li>
          <li class="cvs">Monitoring</li>
          <li class="cvs">Specialist referrals: </li>
          <li class="cvs">Allied health:
            <ul>
              <li class="cvs">Occupational Therapist: </li>
              <li class="cvs">Physio Therapist: </li>
            </ul>
          </li>
        </ul>
      </li>
      <li class="General">Patient Education
        <ul>
          <li class="General">Warning Signs/Red Flags:</li>
          <ul>
            <li class="rheumatic">Gaint cell arteritis</li>
            <ol>
              <li class="rheumatic">Vision disturbances</li>
              <li class="rheumatic">headache</li>
            </ol>
            <li class="General ent cns">Driving</li>
            <li class="General ent cns">Heavy machinery</li>
            <li class="General">Call </li>
            <ol>
              <li class="General">999 - emergency</li>
              <li class="General">112 - emergency</li>
              <li class="General">111 - non emergency</li>
              <li class="General oncology">2-wk-wait coordinator - Cancer</li>
              <li class="psychiatric">111-2 - mental health</li>
              <li class="psychiatric">0300 123 1100 - Acas Helpline </li>
              <li class="psychiatric"> 116 123 Samaritans </li>
              <li class="cns">SUDEP</li>
            </ol>
            <li class="derma">mole --&gt; melanoma</li>
            <li class="nephro">Hyperkalemia - ACE, ARBs, Spironolactone</li>
            <ul class="nephro">
              <li class="nephro"> dont take K+ salt </li>
              <li class="nephro">Muscle weakness, cramps or floppiness</li>
              <li class="nephro">Tingling or pins and needles</li>
              <li class="nephro">Palpitations, chest heaviness or dizziness</li>
              <li class="nephro">Feeling unusually tired or short of breath</li>
            </ul>
          </ul>
          <li class="cvs">DVLA</li>
          <li class="General">Educational materials provided: </li>
          <ul>
            <li class="cvs">Leaflets/</li>
            <ol>
              <li class="derma">British Association of Dermatologists (BAD)
                leaflets</li>
            </ol>
            <li class="cvs">Pamphlets</li>
          </ul>
          <li class="General">Useful resources/links: </li>
        </ul>
      </li>
      <li class="General">Report to the Authorities ?</li>
    </ol>
