  <body>
    <button id="theme-toggle" title="Toggle dark mode">🌙 Dark Mode</button>    <h4>MANAGEMENT PLAN</h4>
    <h4>��� ��� ��� ��� ��� ��� ��� ��� ��� Urgency</h4>
    <ul>
      <li>Urgent Admission:</li>
      <li>Urgent Referral (2 weeks):</li>
      <li>Routine Referral:</li>
      <li>Handling In-House:</li>
    </ul>
    <h4>Patient-Specific Plan</h4>
    <ol>
      <li>Initial Investigations
        <ul>
          <li><em>Consent </em></li>
          <li>Blood work: </li>
          <ul>
            <li>Prostate specific antigen</li>
          </ul>
          <li>Imaging: </li>
          <ul>
            <li>Urine dip stick</li>
            <li>X- Ray</li>
            <ul>
              <li>Multiple myeloma</li>
            </ul>
            <li>MRI</li>
            <li>CT Scan</li>
            <ul>
              <li>Renal stones</li>
            </ul>
            <li>Ultrasound</li>
          </ul>
          <li class="derma">Dermoscopy</li>
          <li class="derma">Photography</li>
          <li class="derma">Biopsy: </li>
          <ul>
            <li class="derma">Excisional biopsy - we dont sample biopsy</li>
            <ul>
              <li class="derma">Mole suspect</li>
              <li class="derma">BCC</li>
              <li class="derma">SCC</li>
            </ul>
            <li class="derma">if positive then wide excision</li>
            <li class="derma"><em>ADR </em>= <em>Complications</em></li>
            <ul>
              <li class="derma">bleeding</li>
              <li class="derma">infection</li>
              <li class="derma">pain</li>
              <li class="derma">scarring</li>
              <li class="derma">disfigurement</li>
            </ul>
          </ul>
          <li>Further Investigations</li>
          <ul>
            <li>Specialized tests: </li>
            <ul>
              <li>Cystoscope</li>
              <li>biopsy</li>
            </ul>
            <li>Referrals: </li>
          </ul>
        </ul>
      </li>
      <li>EXPLAIN FINDINGS</li>
      <li>ICE : <br>
        <strong></strong></li>
      <li><strong>PROVISIONAL &Icirc;&rdquo; :</strong></li>
      <ol>
        <li>ANATOMICAL</li>
        <li>ETIOLOGICAL</li>
        <li>PATHOLOGICAL</li>
        <li>CLINICAL</li>
      </ol>
      <li>Treatment Plan
        <ul>
          <li>Symptomatic treatment: </li>
          <li>Specific treatment: </li>
          <li>Consent </li>
          <li>Non-Medical: </li>
          <ol>
            <li>Watch and wait!</li>
            <li> Chronic fatigue syndrome</li>
            <ol>
              <li>CBT</li>
              <li>Life style</li>
              <li>not graded exercise </li>
            </ol>
            <li> Thalassemia minor<br>
            </li>
            <ol>
              <li>Counselling</li>
              <li>Marrige counselling</li>
              <li>Iron if Severe</li>
            </ol>
            <li>Renal stones</li>
            <ol>
              <li>Strainer for collecting Renal stones</li>
            </ol>
            <li class="derma">Eczema: </li>
            <ul class="derma">
              <li class="derma"> simple = Mouzterizers</li>
            </ul>
          </ol>
          <li>Medical/</li>
          <ul>
            <li class="derma">Severe eczema</li>
            <ul>
              <li class="derma">steroids</li>
            </ul>
            <li class="derma">Acne</li>
            <ul>
              <li class="derma">Retenoids</li>
            </ul>
            <li class="derma">Scabies</li>
            <ul>
              <li class="derma">Permethrin / Ivermectin</li>
            </ul>
            <li>Anti pyretic </li>
            <li>Anti epileptic</li>
            <ul>
              <li>Febrile seizures if the child is far away</li>
            </ul>
            <li>Pain killers</li>
            <ul>
              <li>UTI</li>
              <li>Renal stones</li>
            </ul>
            <li>Abx</li>
            <ul>
              <li>UTI</li>
              <li>Trimithoprim</li>
              <li>Nitrofurantoin</li>
            </ul>
            <li>Tamsulosin</li>
            <ul>
              <li>BPH</li>
            </ul>
            <li>Finasteride</li>
            <ul>
              <li>BPH</li>
            </ul>
            <li>Chemo</li>
            <li>Radio</li>
            <li>Steroids</li>
            <ul>
              <li>ITP</li>
            </ul>
          </ul>
          <li>Surgical</li>
          <ul>
            <li>Stem cell </li>
            <li>Bone Marrow Transplant</li>
            <li>Splenectomy - </li>
            <ul>
              <li>ITP severe</li>
            </ul>
            <li>Stent</li>
            <ul>
              <li>Renal stones</li>
            </ul>
            <li>PCNL</li>
            <ul>
              <li>Renal stones</li>
            </ul>
            <li class="derma">cant do simple cosmetic procedures</li>
            <li class="derma">if lesions causes other problem then Sgx</li>
          </ul>
          <li>Admission required: Yes/No</li>
        </ul>
      </li>
      <li>Follow Up
        <ul>
          <li>Frequency: </li>
          <li>Monitoring</li>
          <li>Specialist referrals: </li>
          <li>Allied health:
            <ul>
              <li>Occupational Therapist: </li>
              <li>Physio Therapist: </li>
            </ul>
          </li>
        </ul>
      </li>
      <li>Patient Education
        <ul>
          <li>Warning Signs/Red Flags:</li>
          <ul>
            <li>Call <em>999 </em>or <em>112</em> </li>
            <li>Call <strong>111</strong></li>
            <li class="derma">mole--&gt; melanoma</li>
            <li>Hyperkalemia - ACE, ARBs, Spironolactone</li>
            <ul>
              <li> dont take K+ salt </li>
              <li>Muscle weakness, cramps or floppiness</li>
              <li>Tingling or pins and needles</li>
              <li>Palpitations, chest heaviness or dizziness</li>
              <li>Feeling unusually tired or short of breath</li>
            </ul>
          </ul>
          <li>Educational materials provided: </li>
          <ul>
            <li>Leaflets/</li>
            <ol>
              <li class="derma">British Association of Dermatologists (BAD)
                leaflets</li>
            </ol>
            <li>Pamphlets</li>
          </ul>
          <li>Useful resources/links: </li>
        </ul>
      </li>
      <li>Report to the Authorities ?</li>
    </ol>
