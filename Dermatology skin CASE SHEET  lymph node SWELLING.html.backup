<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="content-type" content="text/html; charset=windows-1252">
    <title>DERMATOLOGY CASE SHEET</title>
    <style>
      /* A4 Paper Size */
      @page {
        size: A4;
        margin: 2cm;
      }
      
      body {
        font-size: 8pt;
        line-height: 1.4;
        width: 100%;
        margin: 0 auto;
        padding: 0 1cm;
        box-sizing: border-box;
        font-family: 'Times New Roman', times, serif;
      }
      
      /* Lists */
      ol, ul {
        margin-left: 10%;
        padding-left: 0;
      }
      
      ul {
        list-style-type: lower-alpha;
      }
      
      ol {
        list-style-type: decimal;
      }
      
      .section {
        margin-bottom: 15px;
      }
      
      h3 {
        font-size: 9pt;
        font-weight: bold;
        margin-top: 15px;
        margin-bottom: 10px;
        color: #333;
        font-family: 'Times New Roman', times, serif;
      }
      
      h4 {
        font-size: 8pt;
        font-weight: bold;
        margin-top: 10px;
        margin-bottom: 8px;
        color: #444;
        font-family: 'Times New Roman', times, serif;
      }
      
      p {
        margin: 5px 0;
      }
      
      .indent-1 {
        margin-left: 2em;
      }
      
      .indent-2 {
        margin-left: 4em;
      }

      u {
        color: #2100fd;
        text-decoration: none;
        font-weight: bold;
        font-style: normal;
      }

      b {
        color: #fd0054;
        text-decoration: none;
        font-weight: bold;
        font-style: normal;
      }

      em {
        text-decoration: none;
        font-weight: bold;
        font-style: normal;
        color: #08cca2;
      }

      strong {
        color: #09a8cc;
        font-weight: bold;
        font-style: normal;
        text-decoration: none;
      }
      .video-container {
        position: relative;
        width: 100%;
        aspect-ratio: 2/ 1; /* Width:Height = 1:2 */
      }
      
      .video-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
      }
      
      /* Collapsible sections */
      details {
        margin-bottom: 15px;
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 5px 10px;
      }
      
      summary {
        font-weight: bold;
        cursor: pointer;
        padding: 5px;
        outline: none;
      }
      
      summary:hover {
        background-color: #f5f5f5;
      }
      
      .derma {
        font-style: italic;
        color: #666;
        margin: 5px 0 10px 0;
      }
      
      .section-title {
        font-size: 9pt;
        font-weight: bold;
        margin-top: 15px;
        margin-bottom: 10px;
        color: #333;
        border-bottom: 1px solid #ccc;
        padding-bottom: 3px;
      }
    </style>
  </head>
