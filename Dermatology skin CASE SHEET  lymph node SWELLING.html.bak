                <li>Pityriasis rosea</li>
                <li>Contact dermatitis</li>
                <li>Psoriasis</li>
              </ul>
            </li>
            <li> <strong>Back</strong>
              <ul>
                <li>Acne vulgaris</li>
                <li>Psoriasis</li>
                <li>Folliculitis</li>
                <li>Shingles (Herpes zoster)</li>
              </ul>
            </li>
            <li> <strong>Abdomen</strong>
              <ul>
                <li>Pityriasis rosea</li>
                <li>Psoriasis</li>
                <li>Contact dermatitis</li>
                <li>Shingles (Herpes zoster)</li>
              </ul>
            </li>
            <li> <strong>Groin</strong>
              <ul>
                <li>Tinea cruris (jock itch)</li>
