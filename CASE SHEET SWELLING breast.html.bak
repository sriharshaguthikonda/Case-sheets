            margin-bottom: 10px;
            color: #333;
            font-family: 'Times New Roman', times, serif;
          }
        summary {
            font-size: 8pt;
            font-weight: bold;
            color: #333;
            font-family: 'Times New Roman', times, serif;
          }
          
          h4 {
            font-size: 8pt;
            font-weight: bold;
            margin-top: 10px;
            margin-bottom: 8px;
            color: #444;
            font-family: 'Times New Roman', times, serif;
          }

    
          u {
            color: #2100fd;
            text-decoration: none;
            font-weight: bold;
            font-style: normal;
          }
    
          b {
            color: #fd0054;
            text-decoration: none;
            font-weight: bold;
            font-style: normal;
          }
    
          em {
            text-decoration: none;
            font-weight: bold;
            font-style: normal;
            color: #08cca2;
          }
    
