        margin: 0 auto;
        padding: 0 1cm;
        font-family: 'Times New Roman', times, serif;
      }
      
      /* Lists */
      ol, ul {
        margin-left: 10%;
        padding-left: 0;
      }
      
      ul {
        list-style-type: lower-alpha;
      }
      
      ol {
        list-style-type: decimal;
      }
      
      .section {
        margin-bottom: 15px;
      }
      
      h3 {
        font-size: 9pt;
        font-weight: bold;
        margin-top: 15px;
        margin-bottom: 10px;
        color: #333;
        font-family: 'Times New Roman', times, serif;
