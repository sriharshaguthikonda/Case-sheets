  .video-container {
    position: sticky;
    top: 10px;  /* Adjust this value to control how far from the top the video stays */
    float: right;
    width: 50%;  /* Adjust width as needed */

    z-index: 1000;
  }
  
  /* Make the video responsive */
  .video-container iframe {
    width: 100%;
    height: auto;
    aspect-ratio: 16/9;
  }
  
  /* Optional: Add some styling for better appearance */
  .video-container {
    background: #fff;
    padding: 10px;
    border-radius: 8px;
