    <!-- JavaScript goes here -->
    <script>
            document.addEventListener('DOMContentLoaded', function() {
            const timestampLinks = document.querySelectorAll('.timestamp');
            
            timestampLinks.forEach(link => {
                link.addEventListener('click', function(event) {
                    event.preventDefault(); // Prevent the default link navigation
                    const href = this.getAttribute('href');
                    let seconds = null;
                    let videoId = null;
                    
                    // Extract video ID from the YouTube URL
                    const videoIdMatch = href.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]+)/);
                    if (videoIdMatch && videoIdMatch[1]) {
                        videoId = videoIdMatch[1];
                    }
                    
                    // Try to extract time from 't=XXs' format
                    const timeMatchSeconds = href.match(/t=(\d+)s?/); // Made 's' optional
                    if (timeMatchSeconds && timeMatchSeconds[1]) {
                        seconds = timeMatchSeconds[1];
                    } else {
                        // Fallback: Try to extract from '?start=XX' or '&start=XX'
                        const timeMatchStart = href.match(/[?&]start=(\d+)/);
                        if (timeMatchStart && timeMatchStart[1]) {
                            seconds = timeMatchStart[1];
                        }
                    }
                    
                    if (videoId && seconds !== null) {
                        // Find all iframes that contain YouTube embeds
                        const allIframes = document.querySelectorAll('iframe[src*="youtube.com/embed"]');
                        
                        // Find the iframe that matches this video ID
                        let targetIframe = null;
                        allIframes.forEach(iframe => {
                            const iframeSrc = iframe.src;
                            if (iframeSrc.includes(videoId)) {
                                targetIframe = iframe;
                            }
                        });
                        
                        if (targetIframe) {
                            // Extract the base embed URL from the current iframe src
                            const baseEmbedUrl = `https://www.youtube.com/embed/${videoId}`;
                            
                            // Construct the new URL for the iframe to start at the specific time and autoplay
                            targetIframe.src = `${baseEmbedUrl}?start=${seconds}&autoplay=1&rel=0`;
                            // rel=0 attempts to prevent related videos from other channels at the end
                        } else {
                            console.warn(`Could not find iframe for video ID: ${videoId}`);
                        }
                    } else {
                        console.warn("Could not parse video ID or time from link: " + href);
                    }
                });
            });
        });
    </script>

         <script src="harsha_iframe_youtube_player.js"></script>
      <script src="theme-toggle.js"></script>
  </body>
</html>
