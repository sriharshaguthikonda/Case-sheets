          </td>
        </tr>
        <tr>
          <td><strong>Tone</strong></td>
          <td><a href="https://youtu.be/7pIaoULs5do?t=945s" class="timestamp">Passive
              movement of knee and ankle (15:45)</a></td>
          <td><br>
          </td>
          <td><br>
          </td>
        </tr>
      </tbody>
    </table>
