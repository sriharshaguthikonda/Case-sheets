      </thead>
      <tbody>
        <tr>
          <td><strong>Bulk</strong></td>
          <td><a href="https://youtu.be/7pIaoULs5do?t=925s" class="timestamp">Observe
              major muscle groups (15:25)</a></td>
          <td><br>
          </td>
